# Copy to .env and fill in. Never commit the real .env.
# Local dev uses a Docker Postgres container (host port 5440):
#   docker run -d --name aer-postgres -e POSTGRES_USER=aer -e POSTGRES_PASSWORD=aerpass \
#     -e POSTGRES_DB=aer -p 5440:5432 -v aer_pgdata:/var/lib/postgresql/data postgres:16
DATABASE_URL="postgresql://aer:aerpass@localhost:5440/aer?schema=public"
