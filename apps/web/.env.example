# Copy to .env and fill in. Never commit the real .env.
# Local dev uses a Docker Postgres container (host port 5440). Easiest: `docker compose up -d`
# from the repo root (see docker-compose.yml). Or the equivalent one-off:
#   docker run -d --name aer-postgres -e POSTGRES_USER=aer -e POSTGRES_PASSWORD=aerpass \
#     -e POSTGRES_DB=aer -p 5440:5432 -v aer_pgdata:/var/lib/postgresql/data postgres:16
DATABASE_URL="postgresql://aer:aerpass@localhost:5440/aer?schema=public"

# Base URL of the running AER web app. Used by the collector SDK, demo agent, and `pnpm e2e:demo`.
AER_API_BASE_URL="http://localhost:3000"

# Dev-only demo API key (matches the seed). The demo agent uses this to authenticate locally.
# This is a local fixture, not a real secret. Mint a fresh one with `pnpm key:create`, or
# override AER_API_KEY to use a different key.
AER_DEMO_API_KEY="aer_demo_3f7c1a9e5b2d4068a1c3e5f70912abcd"

# --- Auth (Auth.js) ---------------------------------------------------------
# Session/JWT signing secret. REQUIRED for login. Generate: openssl rand -base64 32
AUTH_SECRET="change-me-openssl-rand-base64-32"

# Public base URL of the app — set in production so OAuth callbacks resolve correctly.
# AUTH_URL="https://your-domain.com"

# Google OAuth (OPTIONAL). When both are set, "Continue with Google" appears on /login.
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials,
# Authorized redirect URI: https://your-domain.com/api/auth/callback/google
# AUTH_GOOGLE_ID="..."
# AUTH_GOOGLE_SECRET="..."
