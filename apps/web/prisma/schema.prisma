// Agent Evidence Recorder — Prisma schema.
// Implements the 7 models in docs/DATA_MODEL.md. Security rules in docs/SECURITY.md:
// - ApiKey stores keyHash only (never plaintext).
// - RedactionFinding stores originalHash only (never the raw sensitive value).
// - Every tenant-scoped table carries organizationId + projectId (resolved from the API key).

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum RunStatus {
  running
  completed
  failed
  needs_approval
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum EventType {
  run_started
  user_input
  model_call
  tool_call
  redaction_applied
  human_approval_requested
  human_approval_granted
  error
  final_output
  run_completed
}

enum FindingType {
  email
  phone
  api_key
  bearer_token
  credit_card
  national_id
}

enum Severity {
  low
  medium
  high
}

enum ExportType {
  json
  pdf
}

enum ExportStatus {
  pending
  ready
  failed
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  projects Project[]
  apiKeys  ApiKey[]
  runs     AgentRun[]
}

model Project {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apiKeys      ApiKey[]
  runs         AgentRun[]

  @@index([organizationId])
}

/// API key — stores hash only. Plaintext is shown once at creation and never persisted.
model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String
  name           String
  keyHash        String    @unique
  prefix         String
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([organizationId, projectId])
}

model AgentRun {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String
  agentName      String
  status         RunStatus @default(running)
  riskLevel      RiskLevel @default(low)
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  durationMs     Int?
  costMicroUsd   Int       @default(0)
  eventCount     Int       @default(0)
  redactionCount Int       @default(0)
  metadata       Json?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events       AgentEvent[]
  findings     RedactionFinding[]
  exports      AuditExport[]

  @@index([organizationId, projectId, startedAt])
}

/// Only redacted snapshots are persisted — raw, unredacted payloads are never stored.
model AgentEvent {
  id             String     @id @default(cuid())
  organizationId String
  projectId      String
  runId          String
  seq            Int
  type           EventType
  title          String
  occurredAt     DateTime   @default(now())
  inputRedacted  Json?
  outputRedacted Json?
  riskLevel      RiskLevel?
  costMicroUsd   Int?
  metadata       Json?

  run      AgentRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  findings RedactionFinding[]

  @@unique([runId, seq])
  @@index([organizationId, projectId])
}

/// Redaction finding — stores originalHash only. The raw value is never stored.
model RedactionFinding {
  id             String      @id @default(cuid())
  organizationId String
  projectId      String
  runId          String
  eventId        String?
  findingType    FindingType
  severity       Severity
  fieldPath      String
  originalHash   String
  createdAt      DateTime    @default(now())

  run   AgentRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  event AgentEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([organizationId, projectId])
}

model AuditExport {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String
  runId          String
  type           ExportType   @default(json)
  status         ExportStatus @default(pending)
  contentHash    String?
  packet         Json?
  createdAt      DateTime     @default(now())

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([organizationId, projectId])
}
